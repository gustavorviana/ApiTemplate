{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "author": "",
  "classifications": [
    "Web",
    "API",
    "Clean Architecture"
  ],
  "identity": "Viana.Api",
  "name": "Viana.Api",
  "shortName": "viana-api",
  "sourceName": "ApiTemplate",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "preferNameDirectory": true,
  "symbols": {
    "UseValidation": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Includes FluentValidation support. When enabled, the Result pattern is also required and will be included automatically."
    },
    "DatabaseProvider": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "none",
      "description": "The database provider to use with Entity Framework Core.",
      "choices": [
        {
          "choice": "sqlserver",
          "description": "SQL Server (Microsoft.EntityFrameworkCore.SqlServer)"
        },
        {
          "choice": "postgres",
          "description": "PostgreSQL (Npgsql.EntityFrameworkCore.PostgreSQL)"
        },
        {
          "choice": "mysql",
          "description": "MySQL (Pomelo.EntityFrameworkCore.MySql)"
        },
        {
          "choice": "none",
          "description": "No database configured"
        }
      ]
    },
    "UseSqlServer": {
      "type": "computed",
      "value": "(DatabaseProvider == \"sqlserver\")"
    },
    "UsePostgres": {
      "type": "computed",
      "value": "(DatabaseProvider == \"postgres\")"
    },
    "UseMySQL": {
      "type": "computed",
      "value": "(DatabaseProvider == \"mysql\")"
    },
    "UseDatabase": {
      "type": "computed",
      "value": "(DatabaseProvider != \"none\")"
    },
    "RunMigrationsOnStartup": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "Run EF Core migrations when the application starts (only when database is enabled)."
    },
    "EnableJwt": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "Enables JWT authentication (requires database).",
      "isEnabled": "(DatabaseProvider != \"none\")",
      "isVisible": "(DatabaseProvider != \"none\")"
    },
    "EnableRateLimiting": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Enables rate limiting configuration and RateLimiting extensions"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "condition": "(!UseValidation)",
          "exclude": [
            "Src/ApiTemplate.Application/Validation/**",
            "Src/ApiTemplate.Api/Filters/ValidationActionFilter.cs",
            "Src/ApiTemplate.Application/UseCases/WeatherForecasts/Create/CreateWeatherForecastRequestValidator.cs",
            "ApiTemplate.Tests/Filters/ValidationActionFilterTests.cs"
          ]
        },
        {
          "condition": "(!UseDatabase)",
          "exclude": [
            "Src/ApiTemplate.Application/Core/Entities/User.cs",
            "Src/ApiTemplate.Application/Interfaces/IDbContext.cs",
            "Src/ApiTemplate.Application/Interfaces/IUserRepository.cs",
            "Src/ApiTemplate.Infrastructure/DependencyInjection/DatabaseMigrationRunner.cs",
            "Src/ApiTemplate.Infrastructure/Data",
            "Src/ApiTemplate.Infrastructure/Data/**"
          ]
        },
        {
          "condition": "(!EnableJwt)",
          "exclude": [
            "Src/ApiTemplate.Api/Filters/UnauthorizedAndForbiddenOperationFilter.cs",
            "Src/ApiTemplate.Api/DependencyInjection/JwtExtensions.cs",
            "Src/ApiTemplate.Api/Controllers/AuthController.cs",
            "Src/ApiTemplate.Application/UseCases/Auth",
            "Src/ApiTemplate.Application/UseCases/Auth/**",
            "Src/ApiTemplate.Application/Interfaces/IUserRepository.cs",
            "Src/ApiTemplate.Application/Interfaces/IJwtService.cs",
            "Src/ApiTemplate.Application/Interfaces/IRefreshTokenRepository.cs",
            "Src/ApiTemplate.Application/Core/Entities/User.cs",
            "Src/ApiTemplate.Application/Core/Entities/RefreshToken.cs",
            "Src/ApiTemplate.Infrastructure/Auth",
            "Src/ApiTemplate.Infrastructure/Auth/**",
            "Src/ApiTemplate.Infrastructure/Fakes/FakeUserRepository.cs",
            "Src/ApiTemplate.Infrastructure/Fakes/FakeRefreshTokenRepository.cs",
            "Src/ApiTemplate.Infrastructure/Data/Repositories/UserRepository.cs",
            "Src/ApiTemplate.Infrastructure/Data/Repositories/RefreshTokenRepository.cs",
            "Src/ApiTemplate.Infrastructure/Data/Configurations/UserConfiguration.cs",
            "Src/ApiTemplate.Infrastructure/Data/Configurations/RefreshTokenConfiguration.cs",
            "Tests/ApiTemplate.Tests.Application/UseCases/Auth",
            "Tests/ApiTemplate.Tests.Application/UseCases/Auth/**"
          ]
        },
        {
          "condition": "(!EnableRateLimiting)",
          "exclude": [
            "Src/ApiTemplate.Api/Extensions/RateLimitingExtensions.cs",
            "Src/ApiTemplate.Api/Configuration/RateLimitingOptions.cs"
          ]
        },
        {
          "exclude": [
            ".git/**",
            ".vs/**",
            ".github/**",
            ".gitattributes",
            "LICENSE.txt"
          ]
        }
      ]
    }
  ]
}