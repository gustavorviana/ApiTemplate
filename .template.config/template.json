{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "author": "Gustavo Viana",
  "classifications": [
    "Web",
    "API",
    "Clean Architecture"
  ],
  "identity": "Viana.Api",
  "name": "Viana.Api",
  "shortName": "viana-api",
  "sourceName": "ApiTemplate",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "preferNameDirectory": false,
  "symbols": {
    "UseValidation": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Includes FluentValidation support."
    },
    "DatabaseProvider": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "sqlserver",
      "description": "The database provider to use with Entity Framework Core.",
      "choices": [
        {
          "choice": "sqlserver",
          "description": "SQL Server (Microsoft.EntityFrameworkCore.SqlServer)"
        },
        {
          "choice": "postgres",
          "description": "PostgreSQL (Npgsql.EntityFrameworkCore.PostgreSQL)"
        },
        {
          "choice": "mysql",
          "description": "MySQL (Pomelo.EntityFrameworkCore.MySql)"
        }
      ]
    },
    "UseSqlServer": {
      "type": "computed",
      "value": "(DatabaseProvider == \"sqlserver\")"
    },
    "UsePostgres": {
      "type": "computed",
      "value": "(DatabaseProvider == \"postgres\")"
    },
    "UseMySQL": {
      "type": "computed",
      "value": "(DatabaseProvider == \"mysql\")"
    },
    "RunMigrationsOnStartup": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "Run EF Core migrations when the application starts."
    },
    "EnableJwt": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "Enables JWT authentication."
    },
    "EnablePasswordSecurity": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Enables ISO password strength validation on register (only when JWT is enabled).",
      "isEnabled": "(EnableJwt)",
      "isVisible": "(EnableJwt)"
    },
    "EnableRateLimiting": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Enables rate limiting configuration and RateLimiting extensions."
    },
    "OpenApiProvider": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "swashbuckle",
      "description": "Chooses which library renders the OpenAPI document and UI.",
      "choices": [
        {
          "choice": "swashbuckle",
          "description": "Swashbuckle.AspNetCore + Viana.Results.OpenApi.Swashbuckle filters."
        },
        {
          "choice": "scalar",
          "description": "Microsoft.AspNetCore.OpenApi + Viana.Results.OpenApi transformers, UI rendered by Scalar.AspNetCore."
        }
      ]
    },
    "UseSwashbuckle": {
      "type": "computed",
      "value": "(OpenApiProvider == \"swashbuckle\")"
    },
    "UseScalar": {
      "type": "computed",
      "value": "(OpenApiProvider == \"scalar\")"
    },
    "DbContextName": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "App",
      "description": "Prefix for the DbContext type and factory. Default 'App' -> AppDbContext, IAppDbContext, AppDbContextFactory, IAppDbContextFactory."
    },
    "DbContextFullName": {
      "type": "generated",
      "generator": "regex",
      "dataType": "string",
      "replaces": "AppDbContext",
      "fileRename": "AppDbContext",
      "parameters": {
        "source": "DbContextName",
        "steps": [
          { "regex": "$", "replacement": "DbContext" }
        ]
      }
    },
    "UseDomainProject": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "Extracts Entities/Enums/ValueObjects into a separate ApiTemplate.Domain project."
    },
    "ArchitectureStyle": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "cqrs",
      "description": "Defines how application logic is organized.",
      "choices": [
        {
          "choice": "cqrs",
          "description": "One handler per operation (IUseCaseHandler). Application/UseCases/<Feature>/<Operation>/."
        },
        {
          "choice": "usecase",
          "description": "UseCase-per-feature class with multiple methods injected into controllers."
        }
      ]
    },
    "UseCqrs": {
      "type": "computed",
      "value": "(ArchitectureStyle == \"cqrs\")"
    },
    "UseUseCase": {
      "type": "computed",
      "value": "(ArchitectureStyle == \"usecase\")"
    },
    "DomainNamespace": {
      "type": "generated",
      "generator": "switch",
      "replaces": ".Application.Core",
      "parameters": {
        "evaluator": "C++",
        "datatype": "string",
        "cases": [
          { "condition": "(UseDomainProject)", "value": ".Domain" },
          { "condition": "(!UseDomainProject)", "value": ".Application.Core" }
        ]
      }
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "condition": "(!UseValidation)",
          "exclude": [
            "**/Src/ApiTemplate.Application/MessagesCatalog/Validation.cs",
            "**/Src/ApiTemplate.Application/UseCases/Auth/Login/LoginRequestValidator.cs",
            "**/Src/ApiTemplate.Application/UseCases/Auth/Register/RegisterRequestValidator.cs",
            "**/Src/ApiTemplate.Application/UseCases/WeatherForecasts/Create/CreateWeatherForecastRequestValidator.cs",
            "**/Src/ApiTemplate.Api/Filters/ValidationActionFilter.cs"
          ]
        },
        {
          "condition": "(!EnableJwt)",
          "exclude": [
            "**/Src/ApiTemplate.Api/Filters/UnauthorizedAndForbiddenOperationFilter.cs",
            "**/Src/ApiTemplate.Api/DependencyInjection/JwtExtensions.cs",
            "**/Src/ApiTemplate.Api/Controllers/AuthController.cs",
            "**/Src/ApiTemplate.Application/UseCases/Auth/**",
            "**/Src/ApiTemplate.Application/Interfaces/IJwtService.cs",
            "**/Src/ApiTemplate.Application/Interfaces/IPasswordHasher.cs",
            "**/Src/ApiTemplate.Application/Interfaces/IPasswordSecurityProvider.cs",
            "**/Src/ApiTemplate.Application/Interfaces/ICurrentUser.cs",
            "**/Src/ApiTemplate.Infrastructure/Auth/HttpCurrentUser.cs",
            "**/Src/ApiTemplate.Application/Core/Entities/UserEntity.cs",
            "**/Src/ApiTemplate.Application/Core/Entities/RefreshTokenEntity.cs",
            "**/Src/ApiTemplate.Application/Core/Enums/PasswordStrengthStatus.cs",
            "**/Src/ApiTemplate.Application/Core/Options/PasswordSecurityOptions.cs",
            "**/Src/ApiTemplate.Application/Core/ValueObjects/PasswordStrengthResult.cs",
            "**/Src/ApiTemplate.Application/MessagesCatalog/Auth.cs",
            "**/Src/ApiTemplate.Infrastructure/Auth/**",
            "**/Src/ApiTemplate.Infrastructure/MessagesCatalog/PasswordSecurity.cs",
            "**/Src/ApiTemplate.Domain/Entities/UserEntity.cs",
            "**/Src/ApiTemplate.Domain/Entities/RefreshTokenEntity.cs",
            "**/Src/ApiTemplate.Domain/Enums/PasswordStrengthStatus.cs",
            "**/Src/ApiTemplate.Domain/Options/PasswordSecurityOptions.cs",
            "**/Src/ApiTemplate.Domain/ValueObjects/PasswordStrengthResult.cs",
            "**/Src/ApiTemplate.Infrastructure/Data/Configurations/UserConfiguration.cs",
            "**/Src/ApiTemplate.Infrastructure/Data/Configurations/RefreshTokenConfiguration.cs",
            "**/Tests/ApiTemplate.Tests.Application/UseCases/Auth/**"
          ]
        },
        {
          "condition": "(!EnablePasswordSecurity)",
          "exclude": [
            "**/Src/ApiTemplate.Application/Interfaces/IPasswordSecurityProvider.cs",
            "**/Src/ApiTemplate.Application/Core/Enums/PasswordStrengthStatus.cs",
            "**/Src/ApiTemplate.Application/Core/Options/PasswordSecurityOptions.cs",
            "**/Src/ApiTemplate.Application/Core/ValueObjects/PasswordStrengthResult.cs",
            "**/Src/ApiTemplate.Domain/Enums/PasswordStrengthStatus.cs",
            "**/Src/ApiTemplate.Domain/Options/PasswordSecurityOptions.cs",
            "**/Src/ApiTemplate.Domain/ValueObjects/PasswordStrengthResult.cs",
            "**/Src/ApiTemplate.Infrastructure/Auth/IsoPasswordSecurityProvider.cs",
            "**/Src/ApiTemplate.Infrastructure/MessagesCatalog/PasswordSecurity.cs"
          ]
        },
        {
          "condition": "(!EnableRateLimiting)",
          "exclude": [
            "**/Src/ApiTemplate.Api/Extensions/RateLimitingExtensions.cs",
            "**/Src/ApiTemplate.Api/Configuration/RateLimitingOptions.cs"
          ]
        },
        {
          "condition": "(!UseSwashbuckle)",
          "exclude": [
            "**/Src/ApiTemplate.Api/DependencyInjection/SwaggerExtensions.cs",
            "**/Src/ApiTemplate.Api/Filters/UnauthorizedAndForbiddenOperationFilter.cs"
          ]
        },
        {
          "condition": "(!UseScalar)",
          "exclude": [
            "**/Src/ApiTemplate.Api/DependencyInjection/ScalarExtensions.cs"
          ]
        },
        {
          "condition": "(!UseDomainProject)",
          "exclude": [
            "**/Src/ApiTemplate.Domain/**"
          ]
        },
        {
          "condition": "(UseDomainProject)",
          "exclude": [
            "**/Src/ApiTemplate.Application/Core/**"
          ]
        },
        {
          "exclude": [
            ".git/**",
            ".vs/**",
            ".github/**",
            ".gitattributes",
            "LICENSE.txt",
            "scripts/**",
            "**/*.user",
            "**/bin/**",
            "**/obj/**"
          ]
        }
      ],
      "specialCustomOperations": {
        "**/*.slnx": {
          "operations": [
            {
              "type": "conditional",
              "configuration": {
                "if": [ "<!--#if" ],
                "else": [ "<!--#else" ],
                "elseif": [ "<!--#elseif" ],
                "endif": [ "<!--#endif" ],
                "trim": true,
                "wholeLine": true
              }
            }
          ]
        }
      }
    }
  ]
}
