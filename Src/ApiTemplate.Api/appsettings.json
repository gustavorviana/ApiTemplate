{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "Enabled": false,
    "UseGlobalLimiterOnly": false,
    "GlobalRequestsPerMinute": 100,
    "LoginRequestsPerMinute": 5,
    "AuthenticatedRequestsPerMinute": 60,
    "AdminRequestsPerMinute": 120
  },
  "JwtSettings": {
    "Secret": "super-secret-key-that-should-be-at-least-32-characters-long!",
    "Issuer": "ApiTemplate",
    "Audience": "ApiTemplate",
    "ExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "PasswordSecurity": {
    "MinimumStrength": "Medium"
  },
  "ConnectionStrings": {
//#if (UseSqlServer)
    "DefaultConnection": "Server=localhost;Database=AppDb;Trusted_Connection=True;TrustServerCertificate=True;"
//#elif (UsePostgres)
    "DefaultConnection": "Host=localhost;Port=5432;Database=AppDb;Username=postgres;Password=postgres"
//#elif (UseMySQL)
    "DefaultConnection": "Server=localhost;Port=3306;Database=AppDb;Uid=root;Pwd=root;"
//#endif
  }
}
